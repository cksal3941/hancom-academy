# Copy this file to .env and fill in the values from each provider console.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set true only after Apple sign-in is fully configured.
VITE_FIREBASE_ENABLE_APPLE=false

# Comma-separated admin emails allowed to see board write controls.
VITE_ADMIN_EMAILS=

# Kakao Developers > App > JavaScript key.
# Register http://localhost:5173 and http://127.0.0.1:5173 as Web platform domains.
VITE_KAKAO_MAP_APP_KEY=
